<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>PrimaServletApp</display-name>

    <!-- BenvenutoServlet -->
    <servlet>
        <servlet-name>BenvenutoServlet</servlet-name>
        <servlet-class>com.accademy.BenvenutoServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BenvenutoServlet</servlet-name>
        <url-pattern>/benvenuto</url-pattern>
    </servlet-mapping>

    <!-- InfoServlet -->
    <servlet>
        <servlet-name>InfoServlet</servlet-name>
        <servlet-class>com.accademy.InfoServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>InfoServlet</servlet-name>
        <url-pattern>/info</url-pattern>
    </servlet-mapping>

</web-app>